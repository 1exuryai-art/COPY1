PORT=3000
TIMEZONE=Europe/Warsaw

# Treść strony: json (plik data/site-content.json) lub postgres (Railway PostgreSQL)
CONTENT_STORE=json
DATABASE_URL=
PROJECT_KEY=default

# Sesja admina (podpis cookie) — ustaw długi losowy ciąg w produkcji
SESSION_SECRET=

# Pierwsza konfiguracja konta admina (tylko gdy DATABASE_URL ustawione i brak użytkowników w DB)
ADMIN_SETUP_CODE=

# Fallback gdy brak DATABASE_URL — logowanie env (dev)
ADMIN_LOGIN=
ADMIN_PASSWORD=

# Opcjonalnie: katalog trwały na Railway Volume dla uploadów (domyślnie ./assets/admin-uploads)
# UPLOAD_DIR=/data/uploads

# Gdy postgres: wyłącz ochronę przed zapisem usuwającym wiele sekcji naraz (nie zalecane)
# ALLOW_DESTRUCTIVE_SAVE=1

GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REFRESH_TOKEN=your_google_refresh_token
GOOGLE_CALENDAR_ID=primary

SMSAPI_TOKEN=
SMS_SENDER=MONARCH

CONTACT_PHONE=532377701
OWNER_NOTIFICATION_PHONE=
